  "color_palette": {
    "title_color": "#1A3A5C",
    "text_color": "#2D3436",
    "bullet_color": "#2980B9",
    "list_text_color": "#4A4A4A",
    "image_border_color": "#85C1E9",
    "table_header_bg": "#1A3A5C",
    "table_border_color": "#85C1E9",
    "callout_border_color": "#2980B9",
    "callout_bg_color": "#EBF5FB",
    "chart_color_1": "#2980B9",
    "chart_color_2": "#E74C3C",
    "chart_color_3": "#27AE60",
    "chart_color_4": "#F39C12"
