{
  "id": "hero_section",
  "type": "combined",
  "name": "Section héro avec image latérale",
  "description": "Titre pleine largeur, puis paragraphe (60%) et image (40%) côte à côte",
  "color_palette": {
    "title_color": "#1A3A5C",
    "text_color": "#2D3436",
    "bullet_color": "#2980B9",
    "list_text_color": "#4A4A4A",
    "image_border_color": "#85C1E9",
    "table_header_bg": "#1A3A5C",
    "table_border_color": "#85C1E9",
    "callout_border_color": "#2980B9",
    "callout_bg_color": "#EBF5FB"
  },
  "layout": {
    "type": "grid",
    "rows": [
      {
        "height": "auto",
        "columns": [
          {
            "width_pct": 100,
            "components": [
              { "singular_template": "title", "level": 1 }
            ]
          }
        ]
      },
      {
        "height": "auto",
        "columns": [
          {
            "width_pct": 60,
            "components": [
              { "singular_template": "paragraph" }
            ]
          },
          {
            "width_pct": 40,
            "components": [
              { "singular_template": "image" }
            ]
          }
        ]
      }
    ]
  }
}
