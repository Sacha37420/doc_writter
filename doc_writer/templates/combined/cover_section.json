{
  "id": "cover_section",
  "type": "combined",
  "name": "Section page de couverture",
  "description": "Image centrée, grand titre et sous-titre descriptif pour page de couverture",
  "color_palette": {
    "title_color": "#1A1A2E",
    "text_color": "#2D3436",
    "bullet_color": "#E8A838",
    "list_text_color": "#4A4A4A",
    "image_border_color": "#E8A838",
    "table_header_bg": "#1A1A2E",
    "table_border_color": "#E8A838",
    "callout_border_color": "#E8A838",
    "callout_bg_color": "#FEF9EC"
  },
  "layout": {
    "type": "grid",
    "rows": [
      {
        "height": "auto",
        "columns": [
          {
            "width_pct": 100,
            "components": [
              { "singular_template": "image" }
            ]
          }
        ]
      },
      {
        "height": "auto",
        "columns": [
          {
            "width_pct": 100,
            "components": [
              { "singular_template": "title", "level": 1 }
            ]
          }
        ]
      },
      {
        "height": "auto",
        "columns": [
          {
            "width_pct": 100,
            "components": [
              { "singular_template": "paragraph" }
            ]
          }
        ]
      }
    ]
  }
}
