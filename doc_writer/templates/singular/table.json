{
  "id": "table",
  "type": "table",
  "columns": 3,
  "rows": 4,
  "has_header_row": true,
  "header": {
    "font": {
      "name": "Calibri",
      "size": 8,
      "bold": true,
      "italic": false,
      "color": "#FFFFFF"
    },
    "background_color": "{{table_header_bg}}",
    "alignment": "center"
  },
  "cell": {
    "font": {
      "name": "Calibri",
      "size": 8,
      "bold": false,
      "italic": false,
      "color": "{{text_color}}"
    },
    "alignment": "left",
    "padding_pt": 4
  },
  "border": {
    "color": "{{table_border_color}}",
    "width_pt": 0.5,
    "style": "single"
  }
}
